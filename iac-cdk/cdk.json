{
  "app": "npx ts-node --prefer-ts-exts bin/sentinel.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "node_modules", "dist"]
  },
  "context": {
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/core:target-partitions": ["aws", "aws-cn"],
    "sentinel:appName": "sentinel",
    "sentinel:gatewayAuthorizerType": "AWS_IAM",
    "sentinel:memoryExpiryDays": 90,
    "sentinel:registryAutoApproval": false
  }
}
